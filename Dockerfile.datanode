FROM golang:1.24-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/datanode ./cmd/datanode

FROM alpine:3.19
RUN apk --no-cache add ca-certificates curl
COPY --from=builder /bin/datanode /usr/local/bin/datanode

EXPOSE 9001 9501
ENTRYPOINT ["datanode"]