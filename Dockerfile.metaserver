FROM golang:1.24-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/metaserver ./cmd/metaserver

FROM alpine:3.19
RUN apk --no-cache add ca-certificates netcat-openbsd
COPY --from=builder /bin/metaserver /usr/local/bin/metaserver

EXPOSE 9000
ENTRYPOINT ["metaserver"]
CMD ["--port", "9000"]